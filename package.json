{
  "name": "dkfds-docs",
  "version": "3.0.0",
  "description": "Website and documentation on using the Frontend Styleguide",
  "mode": "none",
  "scripts": {
    "build": "npx webpack --mode production --color",
    "build-examples": "node config\\generate-html.js && node config\\highlight-examples.js",
    "build-html": "gulp html",
    "postinstall": "bundle",
    "start": "bundle exec jekyll serve --incremental --trace --config _config.yml,_config.dev.yml",
    "publish": "npm run build && bundle exec jekyll build --config _config.yml && npm run highlight-code && npm run build-docs",
    "publish-dev": "npm run build && npm run build-examples && bundle exec jekyll build --config _config.yml,_config.dev.yml && npm run highlight-code && npm run build-docs",
    "clean": "node config\\clean.js",
    "build-docs": "node config\\build-docs.js",
    "build-site-dev": "bundle exec jekyll build --config _config.yml,_config.dev.yml",
    "highlight-code": "node config\\highlight-code.js",
    "gen-images": "node config\\puppeteer\\gen-images.js",
    "gen-thumbnails": "node config\\puppeteer\\gen-thumbnails.js",
    "gen-pdf-screenshots": "node config\\puppeteer\\gen-pdf-screenshots.js"
  },
  "dependencies": {
    "dkfds": "11.2.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "ansi-colors": "4.1.3",
    "autoprefixer": "10.4.27",
    "babel-loader": "10.1.1",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "fancy-log": "2.0.0",
    "file-loader": "6.2.0",
    "fs-extra": "11.3.4",
    "gulp": "5.0.1",
    "gulp-cli": "3.1.0",
    "gulp-data": "1.3.1",
    "gulp-flatten": "0.4.0",
    "gulp-if": "3.0.0",
    "gulp-jsbeautifier": "3.0.1",
    "gulp-nunjucks-render": "2.2.3",
    "gulp-rename": "2.1.0",
    "highlight.js": "11.11.1",
    "jquery": "3.7.1",
    "js-beautify": "1.15.4",
    "jsdom": "29.0.1",
    "mini-css-extract-plugin": "2.10.2",
    "postcss-discard-comments": "7.0.6",
    "postcss-loader": "8.2.1",
    "puppeteer": "23.11.1",
    "sass": "1.92.0",
    "sass-loader": "16.0.5",
    "terser-webpack-plugin": "5.4.0",
    "through2": "4.0.2",
    "webpack": "5.105.4",
    "webpack-cli": "7.0.2",
    "webpack-remove-empty-scripts": "1.1.1"
  }
}
